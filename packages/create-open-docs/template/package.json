    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.4.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "next": "^16.2.9",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-pretty-code": "^0.14.3",
